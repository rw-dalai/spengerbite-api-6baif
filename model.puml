@startuml
' ---- Layout & Stil ----
hide empty methods
 
' ---- Legende ----
legend right
<<RichType>>: Stark typisierte Primitive
<<ValueObject>>: Value Objects
<<entity>>: Persistente Entität
<<unique>>: Eindeutige Einschränkung auf Spaltenebene
<<nn>>: Not null
endlegend
 
' ===================== Packages =====================

package "Shared\n(Value Objects)" as P_Shared #EEF6FF {
 
  class Phone << (R,#FFEECC) RichType >> {
    +Value: string <<nn>>
  }
  
  class Email << (R,#FFEECC) RichType >> {
    +Value: string <<nn>>
  }
  
  class Address << (R,#FFEECC) ValueObject >> {
    +Street: string <<nn>>
    +City: string <<nn>>
    +PostalCode: string <<nn>>
    +Country: string <<nn>>
  }
  
  class OpeningHours << (V,#CCEEFF) ValueObject >> {
    +OpenTime: TimeOnly <<nn>>
    +CloseTime: TimeOnly <<nn>>
  }
}

enum UserRole {
  ADMIN,
  CUSTOMER
  RESTAURANT_OWNER
  GUEST
}

package "Customers" as P_Customers #FFF5E6 {

    abstract class Customer {
      +Role: UserRole <<nn>>
    }
    
    class RegisterCustomer {
      +FirstName: string <<nn>>
      +LastName: string <<nn>>
      +Email: Email <<nn>>
      +Phone: Phone
      +Address: Address <<nn>>
      '+Addresses: List<Address> <<nn>>
    }
    
    class AnonymousCustomer {
    }
}



class RestaurantOwner {
  Role: UserRole <<nn>>
}

enum OrderStatus {
  SUBMITTED
  CONFIRMED
  PREPARING
  DELIVERED
  CANCELLED
}

class Order {
  Customer: Customer <<nn>>
  Restaurant: Restaurant <<nn>>
  OrderedAt: DateTime <<nn>>
  OrderState: OrderState <<nn>>
}

class OrderItem {
  Order: Order <<nn>>
  MenuItem: MenuItem <<nn>>
  Quantity: int <<nn>>
  Price: decimal <<nn>>
}

class Restaurant {
  Name: string <<nn>>
  Address: Address <<nn>>
  OpeningHours: OpeningHours <<nn>>
  RestaurantOwner: RestaurantOwner <<nn>>
}

class MenuItem {
  Restaurant: Restaurant <<nn>>
  Name: string <<nn>>
  Price: decimal <<nn>>
}

class Cart {
   Customer: Customer <<nn>>
   Restaurant: Restaurant <<nn>>
   CartItems: List<CartItem> <<nn>>
}

class CartItem {
   Cart: Cart <<nn>>
   MenuItem: MenuItem <<nn>>
   Quantity: int <<nn>>
}


'Beziehungen


' ===================== Beziehungen =====================

RegisterCustomer --|> Customer
AnonymousCustomer --|> Customer

Order "*" -- "1" Customer
Order "*" -- "1" Restaurant
Order "1" -- "*" OrderItem

OrderItem "*" -- "1" MenuItem

Restaurant "1" -- "*" MenuItem
Restaurant "*" -- "1" RestaurantOwner

Cart "1" -- "1" Customer
Cart "*" -- "1" Restaurant
Cart "1" -- "*" CartItem

CartItem "*" -- "1" MenuItem





@enduml